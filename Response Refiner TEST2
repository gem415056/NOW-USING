    function injectRefinerButton() {
        const toolWrapper = document.getElementById('custom-rp-tools');
        if (!toolWrapper) return;

        const divs = Array.from(toolWrapper.children);
        const spacers = divs.filter(el => el.tagName === 'DIV' && el.style.width === '28px' && !el.classList.contains('custom-rp-divider'));

        // 하단 툴바의 네 번째 물리 빈 공간(spacers[3])을 할당
        if (spacers.length < 4) return;

        const targetContainer = spacers[3];
        if (targetContainer.querySelector('.crr-toolbar-btn')) return;

        const btn = document.createElement('button');
        btn.className = 'crr-toolbar-btn relative inline-flex items-center justify-center rounded-full text-sm font-medium transition-colors border border-border bg-card text-line-gray-1 hover:bg-secondary p-0 size-7';
        btn.innerHTML = `<span style="font-size:15px; font-weight:normal; color:${ACCENT_COLOR};">♥</span>`;
        btn.title = '응답 교정 설정';
        btn.addEventListener('click', (e) => { e.stopPropagation(); e.preventDefault(); showSettingsModal(); });

        targetContainer.appendChild(btn);
    }

    // ==========================================
    // AI 메시지 안정화 관측 시스템
    // ==========================================
    let lastLength = 0;
    let idleCounter = 0;

    async function checkLatestAssistantMessage() {
        const config = loadSettings();
        if (!config.apiKey && !config.firebaseScript) return; // API 미지정 시 스캔 보류

        const chatId = getChatRoomId();
        if (!chatId) return;

        try {
            const token = document.cookie.match(/(^| )access_token=([^;]+)/)?.[2];
            if (!token) return;

            const url = `https://contents-api.wrtn.ai/character-chat/v3/chats/${chatId}/messages?limit=1`;
            const res = await fetch(url, { headers: { 'Authorization': 'Bearer ' + token } });
            if (!res.ok) return;

            const json = await res.json();
            const lastMsg = json?.data?.messages?.[0];
            if (!lastMsg || lastMsg.role !== 'assistant') {
                lastLength = 0; idleCounter = 0;
                return;
            }

            const messageId = lastMsg._id || lastMsg.id;
            const text = lastMsg.content || '';
            const curLength = text.length;

            if (messageId !== lastCheckedMessageId) {
                lastCheckedMessageId = messageId;
                lastLength = curLength;
                idleCounter = 0;
                return;
            }

            if (curLength === lastLength && curLength > 0) {
                idleCounter++;
                if (idleCounter >= 2) {
                    const fingerprints = JSON.parse(localStorage.getItem(`${SCRIPT_NS}-fingerprints`) || "[]");
                    if (!fingerprints.includes(messageId)) {
                        fingerprints.push(messageId);
                        localStorage.setItem(`${SCRIPT_NS}-fingerprints`, JSON.stringify(fingerprints.slice(-50)));
                        
                        const groups = Array.from(document.querySelectorAll('div[data-message-group-id]'));
                        const targetGroup = groups.find(g => g.getAttribute('data-message-group-id') === messageId);
                        if (targetGroup) {
                            await processRefiner(text, targetGroup, messageId);
                        }
                    }
                }
            } else {
                lastLength = curLength;
                idleCounter = 0;
            }

        } catch (e) {}
    }

