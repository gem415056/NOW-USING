        overlay.querySelector('#set-turns').value = config.turns;
        overlay.querySelector('#set-username').value = config.userName;
        overlay.querySelector('#set-mode').value = config.mode;
        overlay.querySelector('#set-model').value = config.model;

        overlay.querySelector('#set-enabled').addEventListener('change', saveCurrentState);
        overlay.querySelector('#set-turns').addEventListener('input', saveCurrentState);
        overlay.querySelector('#set-username').addEventListener('input', saveCurrentState);
        overlay.querySelector('#set-mode').addEventListener('change', saveCurrentState);
        overlay.querySelector('#set-model').addEventListener('change', saveCurrentState);

        const apiProv = overlay.querySelector('#api-provider');
        const keyBox = overlay.querySelector('#api-key-box');
        const fbBox = overlay.querySelector('#api-firebase-box');
        const inpKey = overlay.querySelector('#api-key');
        const txtFb = overlay.querySelector('#api-firebase-script');

        apiProv.value = config.provider;
        inpKey.value = config.apiKey;
        txtFb.value = config.firebaseScript;

        const syncApiDisplay = () => {
            if (apiProv.value === 'google') {
                keyBox.style.display = 'flex';
                fbBox.style.display = 'none';
            } else {
                keyBox.style.display = 'none';
                fbBox.style.display = 'flex';
            }
        };
        
        apiProv.addEventListener('change', () => {
            syncApiDisplay();
            saveCurrentState();
        });
        inpKey.addEventListener('input', saveCurrentState);
        txtFb.addEventListener('input', saveCurrentState);
        inpBanned.addEventListener('input', saveCurrentState);

        syncApiDisplay();

        const closeModal = () => overlay.remove();
        overlay.querySelectorAll('[data-close]').forEach(btn => btn.onclick = closeModal);
        overlay.onclick = (e) => { if (e.target === overlay) closeModal(); };

        // 수동 검수 강제 트리거 단추 바인딩 (정중앙 배치)
        overlay.querySelector('#ce-ref-manual-trigger').onclick = async () => {
            closeModal();
            const chatId = getChatRoomId();
            if (!chatId) return showToast("❌ 대화방을 찾을 수 없습니다.", "info");

            showToast("🫧 수동 검수 강제 호출 중...", "info", 1500);
            try {
                const token = document.cookie.match(/(^| )access_token=([^;]+)/)?.[2];
                if (!token) return;

                const url = `https://contents-api.wrtn.ai/character-chat/v3/chats/${chatId}/messages?limit=1`;
                const res = await fetch(url, { headers: { 'Authorization': 'Bearer ' + token } });
                if (!res.ok) return;

                const json = await res.json();
                const lastMsg = json?.data?.messages?.[0];
                if (lastMsg && lastMsg.role === 'assistant') {
                    const messageId = lastMsg._id || lastMsg.id;
                    const text = lastMsg.content || '';

                    // 중복 무시 및 수동 즉시 교정 돌입 (수동 호출은 config.enabled 여부와 상관없이 무조건 가동)
                    isProcessing = false;
                    const groups = Array.from(document.querySelectorAll('div[data-message-group-id]'));
                    const targetGroup = groups.find(g => g.getAttribute('data-message-group-id') === messageId);
                    if (targetGroup) {
                        await processRefiner(text, targetGroup, messageId, true);
                    }
                } else {
                    showToast("❌ 교정할 마지막 AI 응답이 없습니다.", "info");
                }
            } catch (e) {
                showToast(`❌ 수동 교정 에러: ${e.message}`, "info");
            }
        };
    }

