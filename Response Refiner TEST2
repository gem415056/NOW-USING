// @run-at       document-idle
// @require      https://cdn.jsdelivr.net/npm/dexie@4.2.1/dist/dexie.min.js
// ==/UserScript==

(function () {
    'use strict';

    const SCRIPT_NS = 'crack-response-refiner';
    const MODAL_ID = `${SCRIPT_NS}-modal`;
    const ACCENT_COLOR = '#BCD0D7'; // 파스텔 블루그레이
    const ACCENT_HOVER = '#AEC2C9';
    const TOAST_ID = `${SCRIPT_NS}-toast`;

    let activeEditorText = '';
    let isProcessing = false;
    let lastCheckedMessageId = '';
    let checkTimer = null;

    // 동적 컷오프(Pruning) 매핑용 규칙별 지문 원본
    const RULE_TEXTS = {
        banned: `### 1. FORBIDDEN WORDS & SENSORY UPGRADE
If any word from [Forbidden Words] (or synonyms of possession/control/obsession/beast/game/toy) is found:
- Do NOT use abstract conceptual words to describe psychological states. "Show, don't tell."
- Replace with:
  - Non-verbal cues: facial expressions, gaze, breathing, physical distance, subtle gestures, physiological reactions.
  - Silence/Pause: to create subtle tension.
  - Projection: reflecting emotions onto objects, colors, or sounds.
  - Creative Metaphors: Avoid cliché tropes (e.g., "like a wild beast" -> "like a viper coiling in the dark"; "beast-like breathing" -> "like parched earth greedily drinking the first rain").`,

        impersonation: `### 2. USER IMPERSONATION & META-COGNITION PREVENTION
- Do NOT narrate, predict, or decide the user character's actions, dialogue, internal thoughts, emotions, or physical reactions (e.g., moans, expressions) that have not been explicitly input by the user.
- Do NOT let AI characters meta-cognitively perceive thoughts the user only had internally.
- Correction: Replace these parts with the actions, observations, or reactions of the AI characters instead.`,

        overfitting: `### 3. OVERFITTING & REPETITION AVOIDANCE
- Check if [New Speech] replicates or slightly varies sentence structures, specific descriptions, actions, or dialogues from the [Recent Context] (especially the immediate previous turn).
- Correction: Replace with completely different actions, descriptions, or setups to move the narrative forward. Avoid stagnant pacing.`,

        measurement: `### 4. NO SPECIFIC METRIC MEASUREMENTS
- Do NOT use precise physical measurements (e.g., cm, kg, cup sizes, specific numbers) to describe characters' bodies or appearances.
- Correction: Describe through clothing fit, relative comparison to others, physical interactions, or movement.`,

        parroting: `### 5. NO PARROTING
- Do NOT repeat, summarize, or explicitly cite the user's latest input before responding.
- Correction: Assume the user's input has already happened. Advance the timeline and describe the AI character's subsequent observation, interpretation, or reaction.`,

        cliche: `### 6. CLICHÉ NARRATIVE CORRECTION (SLOW BURN)
- If the narrative leans towards a cheap, possessive, or controlling web-novel cliché:
- Correction: Pivot to realistic, multi-layered emotional interactions.
  - Relate through emotional interaction, not power dynamics.
  - Ensure gradual and reasonable character changes (Slow Burn: observation, trust, care, conflict, reconciliation).
  - Diversify positive emotions (longing, protectiveness, fear of loss, responsibility) and negative emotions (confusion, internal conflict, hesitation).`,

        state: `### 7. STATE CONTRADICTION
- Check for inconsistencies in characters' physical states (e.g., wounds, clothing status, life/death, location).
- Example: Putting on clothes that were already removed, or being in a pool but described as dry. Correct these logically.`,

        nsfw: `### 8. NSFW CONTEXT CONTINUITY
- Ensure character consistency and emotional depth before, during, and after sexual intimacy.
- Do NOT reset emotional progression, ignore established personalities, or shift attitudes abruptly for the sake of NSFW scenes.
- Correction: Maintain the established relationship context and personality traits.`,

        unrealistic: `### 9. REALITY & PLAUSIBILITY CHECK
- Correct events that defy common sense, logical plausibility, or physical reality without a narrative justification (e.g., a high schooler driving a car casually -> rewrite to show they are driving unlicensed consciously, or using a chauffeur/public transport).`,

        factual: `### 10. FACT CONTRADICTION
- Ensure [New Speech] does not contradict facts explicitly stated in [Lore] or [Summaries].`,

        promise: `### 11. PROMISE & CONTRACT VIOLATION
- Ensure characters do not violate established promises, rules, or contracts between them unless it is a deliberate narrative choice with visible conflict.`,

        nickname: `### 12. VOCATIVE & TITLE CONTINUITY
- Ensure naming conventions, nicknames, or titles match the current relationship status and context.`,

        presence: `### 13. PRESENCE/ABSENCE CONTRADICTION
- Ensure characters who are not in the current location do not suddenly appear or act without a logical entry scene.`,

        reunion: `### 14. REUNION VIOLATION
- Characters who already know each other (per [Lore] or [Summaries]) must not behave as strangers (e.g., formal self-introductions, "Nice to meet you").`,

        foreigner: `### 15. FOREIGN DIALOGUE FORMAT
- When a foreign character speaks their native tongue (e.g., English), use the format: "English (Korean translation)" (e.g., "Goodbye. (안녕)").
- Exception: This rule does not apply if the foreign character is intentionally attempting to speak Korean.`
    };

    // 검수용 시스템 프롬프트 헤더 및 바디 뼈대
    const DEFAULT_SYSTEM_PROMPT = `You are an RP Continuity and Quality Corrector.
RATE: PG-13 ~ NC-21

## Scope
You receive:
- [Forbidden Words]: Dynamic list of words to avoid and replace.
- [Lore]: Partial character/world data.
- [Summaries]: Memory snapshots.
- [Recent Context]: Last N turns of dialogue.
- [New Speech]: The latest AI-generated RP response to check and correct.

## Core Rule
Review [New Speech] against the active Correction Criteria below. If any violation is found, rewrite the violating parts of [New Speech] to maintain high-quality, realistic, and consistent roleplay. 

---

## Active Correction Criteria & Guidelines
{ACTIVE_RULES_BLOCK}

---

## Output Format
- "reason" MUST be written in Korean.
- No markdown code fences in the JSON output.

If NO issues/repairs are needed:
{passWord}

If issues are found:
{"reason":"교정 이유 (어떤 규칙을 위반했는지 구체적으로 설명)","replacements":[{"from":"원문의 정확한 부분","to":"수정본"}]}

[Forbidden Words]:
{forbidden_words}

[Lore]:
{lore}

[Summaries]:
{memory}

[Recent Context]:
{context}

[New Speech]:
{message}`;

    // Dexie 로어 데이터베이스 인스턴스 초기화
    const loreDb = new Dexie("lore-injector");
    loreDb.version(1).stores({ entries: "++id, name, type, packName, *triggers" });
    loreDb.version(2).stores({ entries: "++id, name, type, packName, project, *triggers" });
    loreDb.version(3).stores({ entries: "++id, name, type, packName, project, *triggers" });
    loreDb.version(4).stores({ entries: "++id, name, type, packName, project, *triggers" });
    loreDb.version(5).stores({ entries: "++id, name, type, packName, project, *triggers" });
    loreDb.version(6).stores({ entries: "++id, name, type, packName, project, rootId, isCurrentArc, *triggers" });
    loreDb.version(7).stores({ entries: "++id, name, type, packName, project, rootId, isCurrentArc, *triggers" });
    loreDb.version(8).stores({ entries: "++id, name, type, packName, model, field, sourceHash, entryUpdatedAt, schemaVersion, &[entryId+field]" });
    loreDb.version(9).stores({ entries: "++id, name, type, packName, project, rootId, isCurrentArc, createdTurn, updatedTurn, lastMentionedTurn, eventTurn, sceneId, arcId, realTimestamp, *entities, *subjects, *objects, *locations, *promises, *triggers" });

    const DEFAULT_SETTINGS = {
        enabled: true,
        turns: 5,
        userName: '',
        model: 'gemini-3.5-flash',
        mode: 'manual', // manual: 수동 승인 팝업, auto: 자동 반영
        provider: 'google',
        apiKey: '',
        firebaseScript: '',
        bannedWords: '소유/통제/지배/정복/주도권/집착/숭배/경배/짐승/맹수/사냥/포식자/먹잇감/게임/유리/장난감/전리품',
        rules: {
            factual: false,
            presence: false,
            nickname: false,
            state: false,
            promise: false,
            reunion: false,
            unrealistic: false,
            foreigner: false,
            impersonation: false,
            parroting: false,
            overfitting: false,
            measurement: false,
            cliche: false,
            banned: false,
            nsfw: false
        }
    };

    function loadSettings() {
        try {
            const saved = localStorage.getItem(`${SCRIPT_NS}-settings`);
            if (saved) {
                const parsed = JSON.parse(saved);
                return { ...DEFAULT_SETTINGS, ...parsed, rules: { ...DEFAULT_SETTINGS.rules, ...parsed.rules } };
            }
        } catch (e) {}
        return { ...DEFAULT_SETTINGS };
    }

    function saveSettings(config) {
        localStorage.setItem(`${SCRIPT_NS}-settings`, JSON.stringify(config));
    }

    function getSafeMainInput() {
        const inputs = document.querySelectorAll('textarea[placeholder*="메시지"], div.__chat_input_textarea, .tiptap.ProseMirror');
        for (const el of inputs) {
            if (el.closest('div[data-message-group-id]')) continue;
            if (el.closest(".flex.w-full.flex-col")) return el;
        }
        return null;
    }

    function getChatRoomId() {
        let m = location.pathname.match(/\/(?:chats|chat|episodes)\/[a-f0-9]+\/([a-f0-9]+)/);
        if (m) return m[1];
        let m2 = location.pathname.match(/\/(?:chats|chat|episodes)\/([a-f0-9]+)/);
        if (m2) return m2[1];
        return null;
    }

    function showToast(message, type = 'info', ms = 3000) {
        let box = document.getElementById(TOAST_ID);
        if (box) box.remove();

        box = document.createElement("div");
        box.id = TOAST_ID;
        box.style.cssText = `
            position: fixed;
            top: calc(50% - 101px);
            left: 50%;
            transform: translate(-50%, -50%) scale(0.9);
            opacity: 0;
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.2), opacity 0.15s ease;
            z-index: 2147483647 !important;
            pointer-events: none;
            display: flex;
            justify-content: center;
            align-items: center;
        `;

        const containerNode = document.createElement("div");
        containerNode.style.cssText = `
            background-color: #23343A;
            border: 1.5px solid ${ACCENT_COLOR};
            padding: 9px 14px;
            border-radius: 9999px;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 4px 16px rgba(0,0,0,0.3);
            box-sizing: border-box;
        `;

        const textNode = document.createElement("p");
        textNode.textContent = message;
        textNode.style.cssText = `
            color: #EFFCFF;
            text-align: center;
            font-size: 12px;
            font-weight: 700;
            line-height: 100%;
            margin: 0;
            padding: 0;
            white-space: nowrap;
            user-select: none;
        `;

        containerNode.append(textNode);
        box.append(containerNode);
        document.body.appendChild(box);

        setTimeout(() => {
            box.style.transform = "translate(-50%, -50%) scale(1)";
            box.style.opacity = "1";
        }, 20);

        setTimeout(() => {
            if (document.body.contains(box)) {
                box.style.transform = "translate(-50%, -50%) scale(0.93)";
                box.style.opacity = "0";
                setTimeout(() => { if (document.body.contains(box)) box.remove(); }, 200);
            }
        }, ms);
    }

    // ==========================================
    // UI 자동화 에디터 입력 및 전송 엔진
    // ==========================================
    function getReactProps(el) {
        const key = Object.keys(el).find(k => k.startsWith('__reactProps'));
        return key ? el[key] : null;
    }

    function firePointerClick(el) {
        const opts = { bubbles: true, cancelable: true };
        el.dispatchEvent(new PointerEvent('pointerover', opts));
        el.dispatchEvent(new PointerEvent('pointerenter', opts));
        el.dispatchEvent(new MouseEvent('mouseenter', opts));
        el.dispatchEvent(new PointerEvent('pointerdown', opts));
        el.dispatchEvent(new PointerEvent('pointerup', opts));
        el.click();
    }

    async function executeUiRefinement(container, correctedText) {
        return new Promise((resolve, reject) => {
            const trigger = container.querySelector('div[aria-haspopup="menu"]');
            if (!trigger) {
                reject(new Error("메시지 제어 메뉴를 찾지 못했습니다."));
                return;
            }

            const style = document.createElement('style');
            style.textContent = `[data-radix-popper-content-wrapper], [role="menu"] { opacity: 0 !important; pointer-events: none !important; }`;
            document.head.appendChild(style);

            firePointerClick(trigger);

            const start = Date.now();
            const findMenuTimer = setInterval(() => {
                const item = Array.from(document.querySelectorAll('div[role="menuitem"]')).find(el => el.textContent.includes('수정'));
                if (item) {
                    clearInterval(findMenuTimer);
                    const props = getReactProps(item);
                    if (props?.onSelect) props.onSelect();
                    else firePointerClick(item);
                    
                    setTimeout(() => style.remove(), 100);
                    
                    const editorStart = Date.now();
                    const findEditorTimer = setInterval(() => {
                        const textarea = container.querySelector('textarea');
                        if (textarea) {
                            clearInterval(findEditorTimer);
                            
                            textarea.value = correctedText;
                            textarea.dispatchEvent(new Event('input', { bubbles: true }));
                            textarea.dispatchEvent(new Event('change', { bubbles: true }));
                            
                            setTimeout(() => {
                                const saveBtn = Array.from(container.querySelectorAll('button')).find(btn => btn.textContent.includes('수정 완료'));
                                if (saveBtn) {
                                    saveBtn.click();
                                    resolve(true);
                                } else {
                                    reject(new Error("수정 완료 버튼을 찾지 못했습니다."));
                                }
                            }, 100);
                        } else if (Date.now() - editorStart > 3000) {
                            clearInterval(findEditorTimer);
                            reject(new Error("텍스트 입력 창 로딩 시간 초과"));
                        }
                    }, 50);
                } else if (Date.now() - start > 1500) {
                    clearInterval(findMenuTimer);
                    style.remove();
                    reject(new Error("수정 권한 확인 메뉴 로딩 실패"));
                }
            }, 30);
        });
    }

    // ==========================================
    // 검수용 백그라운드 API 통신 (로어 인젝터 오리지널 4종 병합 동기화 엔진)
    // ==========================================
    async function fetchSummaries(chatId) {
        const token = document.cookie.match(/(^| )access_token=([^;]+)/)?.[2];
        if (!token) return '메모리 없음.';
        const headers = { 'Authorization': 'Bearer ' + token };
        const result = { goal: [], shortTerm: [], relationship: [], longTerm: [] };
        
        try {
            const endpoints = [
                { key: 'goal', url: `https://contents-api.wrtn.ai/character-chat/v3/chats/${chatId}/summaries?limit=10`, hasTitle: false },
                { key: 'shortTerm', url: `https://crack-api.wrtn.ai/crack-gen/v3/chats/${chatId}/summaries?limit=10&type=shortTerm&orderBy=newest`, hasTitle: true },
                { key: 'relationship', url: `https://crack-api.wrtn.ai/crack-gen/v3/chats/${chatId}/summaries?limit=10&type=relationship&orderBy=newest`, hasTitle: true },
                { key: 'longTerm', url: `https://crack-api.wrtn.ai/crack-gen/v3/chats/${chatId}/summaries?limit=10&type=longTerm&orderBy=newest&filter=all`, hasTitle: true }
            ];

            const fetches = endpoints.map(ep => 
                fetch(ep.url, { headers })
                    .then(res => res.ok ? res.json() : null)
                    .then(json => {
                        const list = json?.data?.summaries || [];
                        result[ep.key] = list.map(s => ep.hasTitle ? `${s.title}: ${s.summary}` : s.summary);
                    })
                    .catch(() => {})
            );
            
            await Promise.all(fetches);

            const lines = [];
            if (result.goal.length) lines.push("[상황 요약]\n" + result.goal.map(s => `- ${s}`).join('\n'));
            if (result.shortTerm.length) lines.push("[단기 기억]\n" + result.shortTerm.map(s => `- ${s}`).join('\n'));
            if (result.relationship.length) lines.push("[관계 변화]\n" + result.relationship.map(s => `- ${s}`).join('\n'));
            if (result.longTerm.length) lines.push("[장기 기억]\n" + result.longTerm.map(s => `- ${s}`).join('\n'));

            return lines.length ? lines.join('\n\n') : '메모리 없음.';
        } catch (e) {
            return '메모리 없음.';
        }
    }

    async function fetchRecentMessages(chatId, limit) {
        const token = document.cookie.match(/(^| )access_token=([^;]+)/)?.[2];
        if (!token) return '';
        try {
            const url = `https://contents-api.wrtn.ai/character-chat/v3/chats/${chatId}/messages?limit=${limit}`;
            const res = await fetch(url, { headers: { 'Authorization': 'Bearer ' + token } });
            if (res.ok) {
                const json = await res.json();
                const msgs = json?.data?.messages || [];
                return msgs.reverse().map(m => {
                    const role = m.role === 'user' ? 'User' : 'Character';
                    return `${role}: ${m.content}`;
                }).join('\n\n');
            }
        } catch(e) {}
        return '';
    }

    async function loadActiveLoreText() {
        try {
            const activePacks = JSON.parse(localStorage.getItem('lore-injector-v5'))?.urlPacks?.[location.pathname] || [];
            if (activePacks.length === 0) return '활성화된 로어 없음.';
            
            const entries = await loreDb.entries.where('packName').anyOf(activePacks).toArray();
            return entries.map(e => `[${e.type}] ${e.name}: ${e.summary?.compact || e.summary || ''}`).join('\n');
        } catch (e) {
            return '로어 로드 오류';
        }
    }

    function compilePrompt(config) {
        const activeRules = [];
        const keysInOrder = [
            'banned', 'impersonation', 'overfitting', 'measurement', 'parroting',
            'cliche', 'state', 'nsfw', 'unrealistic', 'factual',
            'promise', 'nickname', 'presence', 'reunion', 'foreigner'
        ];
        
        keysInOrder.forEach(k => {
            if (config.rules[k] && RULE_TEXTS[k]) {
                activeRules.push(RULE_TEXTS[k]);
            }
        });

        const activeRulesBlock = activeRules.length > 0 
            ? activeRules.join('\n\n') 
            : "No active rules selected. General consistency verification only.";

        return DEFAULT_SYSTEM_PROMPT.replace('{ACTIVE_RULES_BLOCK}', activeRulesBlock);
    }

    async function processRefiner(assistantText, container, messageId, isManual = false) {
        if (isProcessing) return;
        isProcessing = true;
        showToast("🫧 에리가 응답 검수 중", "info", 1500);

        const config = loadSettings();
        if (!config.enabled && !isManual) { isProcessing = false; return; } // 수동일 때는 ON/OFF 무관 강제 가동

        const chatId = getChatRoomId();
        if (!chatId) { isProcessing = false; return; }

        try {
            const contextText = await fetchRecentMessages(chatId, config.turns);
            const loreText = await loadActiveLoreText();
            const memoryText = await fetchSummaries(chatId);
            const systemPrompt = compilePrompt(config);

            const prompt = systemPrompt
                .replace('{lore}', loreText)
                .replace('{context}', contextText)
                .replace('{message}', assistantText)
                .replace('{memory}', memoryText)
                .replace('{forbidden_words}', config.bannedWords || 'None')
                .replace('{passWord}', 'PASS');

            let responseText = '';
            if (config.provider === 'google') {
                if (!config.apiKey) throw new Error("API Key가 설정되어 있지 않습니다.");
                const url = `https://generativelanguage.googleapis.com/v1beta/models/${config.model}:generateContent?key=${config.apiKey}`;
                const payload = { contents: [{ role: "user", parts: [{ text: prompt }] }] };
                
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!res.ok) throw new Error("Gemini API 전송 오류");
                const data = await res.json();
                responseText = data.candidates[0].content.parts[0].text;
            } else {
                if (!config.firebaseScript) throw new Error("Firebase 스크립트가 설정되어 있지 않습니다.");
                const parseFirebase = (scriptStr) => {
                    const match = scriptStr.match(/firebaseConfig\s*=\s*(\{[\s\S]*?\});/);
                    if (match && match[1]) return new Function("return " + match[1])();
                    return null;
                };
                const fbConfig = parseFirebase(config.firebaseScript);
                if (!fbConfig) throw new Error("Firebase Config 파싱 실패");

                const { initializeApp } = await import("https://www.gstatic.com/firebasejs/12.8.0/firebase-app.js");
                const { getAI, getGenerativeModel, VertexAIBackend, HarmBlockThreshold, HarmCategory } = await import("https://www.gstatic.com/firebasejs/12.8.0/firebase-ai.js");

                const app = initializeApp(fbConfig, "crack-refiner-" + Date.now());
                const ai = getAI(app, { backend: new VertexAIBackend('global') });
                const safety = [
                    { category: HarmCategory.HARM_CATEGORY_HATE_SPEECH, threshold: HarmBlockThreshold.OFF },
                    { category: HarmCategory.HARM_CATEGORY_SEXUALLY_EXPLICIT, threshold: HarmBlockThreshold.OFF },
                    { category: HarmCategory.HARM_CATEGORY_HARASSMENT, threshold: HarmBlockThreshold.OFF },
                    { category: HarmCategory.HARM_CATEGORY_DANGEROUS_CONTENT, threshold: HarmBlockThreshold.OFF }
                ];
                const model = getGenerativeModel(ai, { model: config.model, safetySettings: safety });
                const result = await model.generateContent(prompt);
                const resp = await result.response;
                responseText = resp.text();
            }

            const cleanResponse = responseText.trim();
            if (cleanResponse === 'PASS' || cleanResponse.includes('PASS') && cleanResponse.length < 15) {
                showToast("🫧 이상 없음 (통과)", "success", 1500);
                isProcessing = false;
                return;
            }

            let parsed = null;
            try {
                const rawJson = cleanResponse.replace(/^```json\s*/i, "").replace(/\s*```$/i, "").trim();
                parsed = JSON.parse(rawJson);
            } catch (e) {
                showToast("🫧 검수 해석 실패 (패스)", "info", 1500);
                isProcessing = false;
                return;
            }

            if (parsed && (parsed.replacements || parsed.refined_text)) {
                let correctedText = assistantText;
                const replacements = parsed.replacements || [];
                if (replacements.length > 0) {
                    for (const r of replacements) {
                        if (r.from && r.to !== undefined) {
                            correctedText = correctedText.replace(r.from, r.to);
                        }
                    }
                } else if (parsed.refined_text) {
                    correctedText = parsed.refined_text;
                }

                if (correctedText === assistantText) {
                    showToast("🫧 교정 해당사항 없음", "success", 1500);
                    isProcessing = false;
                    return;
                }

                const applyAction = async (finalText) => {
                    showToast("🫧 교정 적용 중...", "info", 1500);
                    try {
                        await executeUiRefinement(container, finalText);
                        showToast("🫧 교정 적용 완료!", "success", 2000);
                    } catch (err) {
                        showToast(`❌ 적용 실패: ${err.message}`, "info", 3000);
                    } finally {
                        isProcessing = false;
                    }
                };

                if (config.mode === 'auto') {
                    await applyAction(correctedText);
                } else {
                    showConfirmModal(parsed.reason, correctedText, applyAction, () => { isProcessing = false; });
                }
            } else {
                isProcessing = false;
            }

        } catch (e) {
            showToast(`❌ 교정 실패: ${e.message}`, "info", 3000);
            isProcessing = false;
        }
    }

