            card.onclick = (e) => {
                if (e.target.tagName === 'INPUT' || e.target.id === 'banned-words') return;
                if (chk) {
                    chk.checked = !chk.checked;
                    chk.dispatchEvent(new Event('change', { bubbles: true }));
                }
            };

            if (chk) {
                chk.addEventListener('change', () => {
                    card.classList.toggle('active', chk.checked);
                    saveCurrentState();
                });
            }
        });

        const chkBanned = overlay.querySelector('#chk-banned');
        const bannedBox = overlay.querySelector('#banned-input-container');
        const inpBanned = overlay.querySelector('#banned-words');
        const bannedCard = chkBanned.closest('.crr-rule-card');
        inpBanned.value = config.bannedWords;

        const syncBannedDisplay = (isInitial = false) => {
            const active = chkBanned.checked;
            bannedCard.classList.toggle('active', active);
            
            if (active) {
                bannedBox.classList.add('open');
                if (!isInitial) {
                    setTimeout(() => {
                        inpBanned.focus();
                        inpBanned.select();
                    }, 180);
                }
            } else {
                bannedBox.classList.remove('open');
            }
        };
        chkBanned.onchange = () => {
            syncBannedDisplay(false);
            saveCurrentState();
        };
        syncBannedDisplay(true);

