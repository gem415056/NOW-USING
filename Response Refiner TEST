                fbBox.style.display = 'none';
            } else {
                keyBox.style.display = 'none';
                fbBox.style.display = 'flex';
            }
        };
        apiProv.onchange = syncApiDisplay;
        syncApiDisplay();

        const closeModal = () => overlay.remove();
        overlay.querySelectorAll('[data-close]').forEach(btn => btn.onclick = closeModal);
        overlay.onclick = (e) => { if (e.target === overlay) closeModal(); };

        overlay.querySelector('#ce-ref-save-settings').onclick = () => {
            config.turns = parseInt(overlay.querySelector('#set-turns').value, 10) || 5;
            config.userName = overlay.querySelector('#set-username').value.trim();
            config.mode = overlay.querySelector('#set-mode').value;
            config.model = overlay.querySelector('#set-model').value;

            overlay.querySelectorAll('[data-rule]').forEach(chk => {
                const k = chk.dataset.rule;
                if (k) config.rules[k] = chk.checked;
            });

            config.bannedWords = inpBanned.value.trim();
            config.provider = apiProv.value;
            config.apiKey = inpKey.value.trim();
            config.firebaseScript = txtFb.value.trim();

            saveSettings(config);
            showToast("🫧 설정이 반영되었습니다.", "success", 1500);
            closeModal();
        };
