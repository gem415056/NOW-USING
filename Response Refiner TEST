// ==UserScript==
// @name         크랙 AI 응답 교정기 (Response Refiner V1.0)
// @namespace    https://crack.wrtn.ai/
// @version      1.0.0
// @description  UI 자동 클릭 방식을 사용하는 고성능/경량화 AI 응답 검수 및 교정기
// @author       User & Gemini
// @match        https://crack.wrtn.ai/*
// @grant        GM_addStyle
// @grant        GM_xmlhttpRequest
// @connect      generativelanguage.googleapis.com
// @connect      googleapis.com
// @connect      firebasevertexai.googleapis.com
// @connect      www.gstatic.com
// @run-at       document-idle
// @require      https://cdn.jsdelivr.net/npm/dexie@4.2.1/dist/dexie.min.js
// ==/UserScript==

(function () {
    'use strict';

    const SCRIPT_NS = 'crack-response-refiner';
    const MODAL_ID = `${SCRIPT_NS}-modal`;
    const ACCENT_COLOR = '#BCD0D7'; // 지정하신 파스텔 블루그레이
    const ACCENT_HOVER = '#AEC2C9';
    const TOAST_ID = `${SCRIPT_NS}-toast`;

    let activeEditorText = '';
    let isProcessing = false;
    let lastCheckedMessageId = '';
    let checkTimer = null;
    let observer = null;

    // Dexie를 통해 기존 로어 인젝터 DB("lore-injector")에 접근하여 로어팩 데이터를 읽어옵니다.
    const loreDb = new Dexie("lore-injector");
    loreDb.version(1).stores({ entries: "++id, name, type, packName, *triggers" });
    loreDb.version(2).stores({ entries: "++id, name, type, packName, project, *triggers" });
    loreDb.version(3).stores({ entries: "++id, name, type, packName, project, *triggers" });
    loreDb.version(4).stores({ entries: "++id, name, type, packName, project, *triggers" });
    loreDb.version(5).stores({ entries: "++id, name, type, packName, project, *triggers" });
    loreDb.version(6).stores({ entries: "++id, name, type, packName, project, rootId, isCurrentArc, *triggers" });
    loreDb.version(7).stores({ entries: "++id, name, type, packName, project, rootId, isCurrentArc, *triggers" });
    loreDb.version(8).stores({ entries: "++id, name, type, packName, model, field, sourceHash, entryUpdatedAt, schemaVersion, &[entryId+field]" });
    loreDb.version(9).stores({ entries: "++id, name, type, packName, project, rootId, isCurrentArc, createdTurn, updatedTurn, lastMentionedTurn, eventTurn, sceneId, arcId, realTimestamp, *entities, *subjects, *objects, *locations, *promises, *triggers" });

    // 기본 설정값 정의
    const DEFAULT_SETTINGS = {
        turns: 5,
        userName: '',
        model: 'gemini-3.1-flash-lite-preview',
        mode: 'manual', // manual: 수동 승인 팝업, auto: 자동 반영
        provider: 'google',
        apiKey: '',
        firebaseScript: '',
        bannedWords: '통제/소유/짐승/맹수/유리',
        promptText: '프롬프트', // 사용자가 직접 채워나갈 커스텀 공간
        rules: {
            factual: true,
            presence: true,
            nickname: true,
            state: true,
            promise: true,
            reunion: true,
            unrealistic: true,
            foreigner: false,
            impersonation: true,
            parroting: true,
            overfitting: true,
            measurement: false,
            cliche: false,
            banned: false
        }
    };

    // 로컬 스토리지에서 설정을 로드합니다.
    function loadSettings() {
        try {
            const saved = localStorage.getItem(`${SCRIPT_NS}-settings`);
            if (saved) {
                const parsed = JSON.parse(saved);
                return { ...DEFAULT_SETTINGS, ...parsed, rules: { ...DEFAULT_SETTINGS.rules, ...parsed.rules } };
            }
        } catch (e) {}
        return { ...DEFAULT_SETTINGS };
    }

    function saveSettings(config) {
        localStorage.setItem(`${SCRIPT_NS}-settings`, JSON.stringify(config));
    }

    // [도움함수] 메인 입력창 탐색
    function getSafeMainInput() {
        const inputs = document.querySelectorAll('textarea[placeholder*="메시지"], div.__chat_input_textarea, .tiptap.ProseMirror');
        for (const el of inputs) {
            if (el.closest('div[data-message-group-id]')) continue;
            if (el.closest(".flex.w-full.flex-col")) return el;
        }
        return null;
    }

    function getChatRoomId() {
        let m = location.pathname.match(/\/(?:chats|chat|episodes)\/[a-f0-9]+\/([a-f0-9]+)/);
        if (m) return m[1];
        let m2 = location.pathname.match(/\/(?:chats|chat|episodes)\/([a-f0-9]+)/);
        if (m2) return m2[1];
        return null;
    }

    // 알림 토스트 (중앙 101px 위 배치 스타일 상속)
    function showToast(message, type = 'info', ms = 3000) {
        let box = document.getElementById(TOAST_ID);
        if (box) box.remove();

        box = document.createElement("div");
        box.id = TOAST_ID;
        box.style.cssText = `
            position: fixed;
            top: calc(50% - 101px);
            left: 50%;
            transform: translate(-50%, -50%) scale(0.9);
            opacity: 0;
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.2), opacity 0.15s ease;
            z-index: 2147483647 !important;
            pointer-events: none;
            display: flex;
            justify-content: center;
            align-items: center;
        `;

        const containerNode = document.createElement("div");
        containerNode.style.cssText = `
            background-color: #23343A;
            border: 1.5px solid ${ACCENT_COLOR};
            padding: 9px 14px;
            border-radius: 9999px;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 4px 16px rgba(0,0,0,0.3);
            box-sizing: border-box;
        `;

        const textNode = document.createElement("p");
        textNode.textContent = message;
        textNode.style.cssText = `
            color: #EFFCFF;
            text-align: center;
            font-size: 12px;
            font-weight: 700;
            line-height: 100%;
            margin: 0;
            padding: 0;
            white-space: nowrap;
            user-select: none;
        `;

        containerNode.append(textNode);
        box.append(containerNode);
        document.body.appendChild(box);

        setTimeout(() => {
            box.style.transform = "translate(-50%, -50%) scale(1)";
            box.style.opacity = "1";
        }, 20);

        setTimeout(() => {
            if (document.body.contains(box)) {
                box.style.transform = "translate(-50%, -50%) scale(0.93)";
                box.style.opacity = "0";
                setTimeout(() => { if (document.body.contains(box)) box.remove(); }, 200);
            }
        }, ms);
    }

    // ==========================================
    // 핵심 동작: UI 자동 수정 파이프라인
    // ==========================================
    function getReactProps(el) {
        const key = Object.keys(el).find(k => k.startsWith('__reactProps'));
        return key ? el[key] : null;
    }

    function firePointerClick(el) {
        const opts = { bubbles: true, cancelable: true };
        el.dispatchEvent(new PointerEvent('pointerover', opts));
        el.dispatchEvent(new PointerEvent('pointerenter', opts));
        el.dispatchEvent(new MouseEvent('mouseenter', opts));
        el.dispatchEvent(new PointerEvent('pointerdown', opts));
        el.dispatchEvent(new PointerEvent('pointerup', opts));
        el.click();
    }

    // 순정 UI 자동 클릭 교정 반영 엔진
    async function executeUiRefinement(container, correctedText) {
        return new Promise((resolve, reject) => {
            const trigger = container.querySelector('div[aria-haspopup="menu"]');
            if (!trigger) {
                reject(new Error("메시지 제어 메뉴를 찾지 못했습니다."));
                return;
            }

            // 메뉴 레이아웃 숨김 처리하여 덜 산만하게 연출
            const style = document.createElement('style');
            style.textContent = `[data-radix-popper-content-wrapper], [role="menu"] { opacity: 0 !important; pointer-events: none !important; }`;
            document.head.appendChild(style);

            firePointerClick(trigger);

            const start = Date.now();
            const findMenuTimer = setInterval(() => {
                const item = Array.from(document.querySelectorAll('div[role="menuitem"]')).find(el => el.textContent.includes('수정'));
                if (item) {
                    clearInterval(findMenuTimer);
                    const props = getReactProps(item);
                    if (props?.onSelect) props.onSelect();
                    else firePointerClick(item);
                    
                    setTimeout(() => style.remove(), 100);
                    
                    // 에디터 열림 및 전송 단계 돌입
                    const editorStart = Date.now();
                    const findEditorTimer = setInterval(() => {
                        const textarea = container.querySelector('textarea');
                        if (textarea) {
                            clearInterval(findEditorTimer);
                            
                            // 텍스트 주입 및 React 강제 트리거
                            textarea.value = correctedText;
                            textarea.dispatchEvent(new Event('input', { bubbles: true }));
                            textarea.dispatchEvent(new Event('change', { bubbles: true }));
                            
                            // "수정 완료" 전송 버튼 클릭
                            setTimeout(() => {
                                const saveBtn = Array.from(container.querySelectorAll('button')).find(btn => btn.textContent.includes('수정 완료'));
                                if (saveBtn) {
                                    saveBtn.click();
                                    resolve(true);
                                } else {
                                    reject(new Error("수정 완료 버튼을 찾지 못했습니다."));
                                }
                            }, 100);
                        } else if (Date.now() - editorStart > 3000) {
                            clearInterval(findEditorTimer);
                            reject(new Error("텍스트 입력 창 로딩 시간 초과"));
                        }
                    }, 50);
                } else if (Date.now() - start > 1500) {
                    clearInterval(findMenuTimer);
                    style.remove();
                    reject(new Error("수정 권한 확인 메뉴 로딩 실패"));
                }
            }, 30);
        });
    }

    // ==========================================
    // 검수 비동기 처리 파이프라인
    // ==========================================
    async function fetchRecentMessages(chatId, limit) {
        const token = document.cookie.match(/(^| )access_token=([^;]+)/)?.[2];
        if (!token) return '';
        try {
            const url = `https://contents-api.wrtn.ai/character-chat/v3/chats/${chatId}/messages?limit=${limit}`;
            const res = await fetch(url, {
                headers: { 'Authorization': 'Bearer ' + token }
            });
            if (res.ok) {
                const json = await res.json();
                const msgs = json?.data?.messages || [];
                return msgs.reverse().map(m => {
                    const role = m.role === 'user' ? 'User' : 'Character';
                    return `${role}: ${m.content}`;
                }).join('\n\n');
            }
        } catch(e) {}
        return '';
    }

    // 기존 데이터베이스에서 활성 로어팩 텍스트 취합
    async function loadActiveLoreText() {
        try {
            const activePacks = JSON.parse(localStorage.getItem('lore-injector-v5'))?.urlPacks?.[location.pathname] || [];
            if (activePacks.length === 0) return '활성화된 로어 없음.';
            
            const entries = await loreDb.entries.where('packName').anyOf(activePacks).toArray();
            return entries.map(e => `[${e.type}] ${e.name}: ${e.summary?.compact || e.summary || ''}`).join('\n');
        } catch (e) {
            return '로어 로드 오류';
        }
    }

    // 규칙 기반 동적 프롬프트 구성
    function compilePrompt(config) {
        const rules = [];
        if (config.rules.factual) rules.push("1. EXPLICIT FACTUAL CONTRADICTION: [Lore] 및 장기 기억 속 명시된 정보와 모순되는 내용을 교정하시오.");
        if (config.rules.presence) rules.push("2. PRESENCE / ABSENCE CONTRADICTION: 현 장소에 없거나 퇴장한 인물이 불쑥 행동하는 모순을 교정하시오.");
        if (config.rules.nickname) rules.push("3. NICKNAME / TITLE MISMATCH: 인물 간 규칙에 반하는 잘못된 별명이나 명칭 사용을 교정하시오.");
        if (config.rules.state) rules.push("4. STATE CONTRADICTION: 상처, 피로도, 생사 상태 등 현재 처해진 신체적 모순을 교정하시오.");
        if (config.rules.promise) rules.push("5. PROMISE / ARC CONTRADICTION: 이전에 맹약했거나 진행 중인 계약 사실 위반을 교정하시오.");
        if (config.rules.reunion) rules.push("6. REUNION VIOLATION: 이미 구면임에도 자기소개를 하거나 어색하게 존대하는 초면 묘사 오류를 교정하시오.");
        if (config.rules.unrealistic) rules.push("7. UNREALISTIC EVENTS: 사회적 상식이나 물리적 개연성에서 어긋난 이상 행동을 개연성 있게 교정하시오.");
        if (config.rules.foreigner) rules.push(`8. FOREIGN LANGUAGE FORMAT: 외국인 캐릭터가 말할 때는 반드시 "영어 (한국어 의역)" 형태로 대사를 한 번에 출력하도록 교정하시오.`);
        if (config.rules.impersonation) rules.push(`9. USER IMPERSONATION: 유저 캐릭터(${config.userName})의 대사, 행동, 심리 서술을 AI가 대신 결정하고 사칭하여 쓴 구절을 즉각 삭제 혹은 3인칭 관찰 묘사로 우회하십시오.`);
        if (config.rules.parroting) rules.push("10. PARROTING / ECHOING: 직전 USER의 묘사나 대사를 그대로 복사해 반복하며 대답하는 무의미한 앵무새 구절을 과감히 제거하시오.");
        if (config.rules.overfitting) rules.push("11. OVERFITTING & REPETITION: 바로 이전 턴에서 묘사한 몸짓, 구조, 대사, 분위기를 지루하게 재사용하거나 자가복제한 요소를 다채롭게 수정하시오.");
        if (config.rules.measurement) rules.push("12. TECHNICAL MEASUREMENT UNITS: 외형을 묘사할 때 cm, kg, 컵 등의 기계식 단위를 배제하고 문학적인 미사여구로 승화시켜 서술하십시오.");
        if (config.rules.cliche) rules.push("13. NO CHEAP CLICHES: 웹소설 특유의 작위적이고 전형적인 집착/소유 서사 클리셰를 쳐내고, 자연스러운 심리 변화를 유지하십시오.");
        if (config.rules.banned && config.bannedWords) {
            const list = config.bannedWords.split('/').map(w => w.trim()).filter(Boolean);
            if (list.length) {
                rules.push(`14. BANNED WORDS FILTER: 다음 단어들 [${list.join(', ')}]을 대사 및 서술에서 절대 사용하지 말고 은유적인 행동으로 풀어서 고쳐 묘사하십시오.`);
            }
        }

        return `You are an RP Continuity Checker.
RATE: PG-13 ~ NC-21

## Scope
You receive:
- [Lore]: partial character/world data
- [Recent Context]: last N turns of dialogue
- [New Speech]: the latest AI-generated RP response

## Rule
Flag an error ONLY when [New Speech] violates the style guidelines or contradicts a fact explicitly stated in [Lore].

## What Counts as an Error
${rules.join('\n')}

## Output Format
Reason MUST be in Korean.
No issues/repairs needed:
PASS

Issues found (no markdown code fences):
{"reason":"교정 이유","replacements":[{"from":"원문의 정확한 부분","to":"수정본"}]}

[Lore]:
{lore}

[Recent Context]:
{context}

[New Speech]:
{message}`;
    }

    async function processRefiner(assistantText, container, messageId) {
        if (isProcessing) return;
        isProcessing = true;
        showToast("🫧 에리가 응답 검수 중", "info", 1500);

        const config = loadSettings();
        const chatId = getChatRoomId();
        if (!chatId) { isProcessing = false; return; }

        try {
            const contextText = await fetchRecentMessages(chatId, config.turns);
            const loreText = await loadActiveLoreText();
            const systemPrompt = compilePrompt(config);

            const prompt = systemPrompt
                .replace('{lore}', loreText)
                .replace('{context}', contextText)
                .replace('{message}', assistantText)
                .replace('{passWord}', 'PASS');

            let responseText = '';
            if (config.provider === 'google') {
                if (!config.apiKey) throw new Error("API Key가 설정되어 있지 않습니다.");
                const url = `https://generativelanguage.googleapis.com/v1beta/models/${config.model}:generateContent?key=${config.apiKey}`;
                const payload = { contents: [{ role: "user", parts: [{ text: prompt }] }] };
                
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!res.ok) throw new Error("Gemini API 전송 오류");
                const data = await res.json();
                responseText = data.candidates[0].content.parts[0].text;
            } else {
                // Firebase SDK 통신
                if (!config.firebaseScript) throw new Error("Firebase 스크립트가 설정되어 있지 않습니다.");
                const parseFirebase = (scriptStr) => {
                    const match = scriptStr.match(/firebaseConfig\s*=\s*(\{[\s\S]*?\});/);
                    if (match && match[1]) return new Function("return " + match[1])();
                    return null;
                };
                const fbConfig = parseFirebase(config.firebaseScript);
                if (!fbConfig) throw new Error("Firebase Config 파싱 실패");

                const { initializeApp } = await import("https://www.gstatic.com/firebasejs/12.8.0/firebase-app.js");
                const { getAI, getGenerativeModel, VertexAIBackend, HarmBlockThreshold, HarmCategory } = await import("https://www.gstatic.com/firebasejs/12.8.0/firebase-ai.js");

                const app = initializeApp(fbConfig, "crack-refiner-" + Date.now());
                const ai = getAI(app, { backend: new VertexAIBackend('global') });
                const safety = [
                    { category: HarmCategory.HARM_CATEGORY_HATE_SPEECH, threshold: HarmBlockThreshold.OFF },
                    { category: HarmCategory.HARM_CATEGORY_SEXUALLY_EXPLICIT, threshold: HarmBlockThreshold.OFF },
                    { category: HarmCategory.HARM_CATEGORY_HARASSMENT, threshold: HarmBlockThreshold.OFF },
                    { category: HarmCategory.HARM_CATEGORY_DANGEROUS_CONTENT, threshold: HarmBlockThreshold.OFF }
                ];
                const model = getGenerativeModel(ai, { model: config.model, safetySettings: safety });
                const result = await model.generateContent(prompt);
                const resp = await result.response;
                responseText = resp.text();
            }

            const cleanResponse = responseText.trim();
            if (cleanResponse === 'PASS' || cleanResponse.includes('PASS') && cleanResponse.length < 15) {
                showToast("🫧 이상 없음 (통과)", "success", 1500);
                isProcessing = false;
                return;
            }

            let parsed = null;
            try {
                const rawJson = cleanResponse.replace(/^```json\s*/i, "").replace(/\s*```$/i, "").trim();
                parsed = JSON.parse(rawJson);
            } catch (e) {
                showToast("🫧 검수 해석 실패 (패스)", "info", 1500);
                isProcessing = false;
                return;
            }

            if (parsed && (parsed.replacements || parsed.refined_text)) {
                let correctedText = assistantText;
                const replacements = parsed.replacements || [];
                if (replacements.length > 0) {
                    for (const r of replacements) {
                        if (r.from && r.to !== undefined) {
                            correctedText = correctedText.replace(r.from, r.to);
                        }
                    }
                } else if (parsed.refined_text) {
                    correctedText = parsed.refined_text;
                }

                if (correctedText === assistantText) {
                    showToast("🫧 치환 불필요 (통과)", "success", 1500);
                    isProcessing = false;
                    return;
                }

                const applyAction = async (finalText) => {
                    showToast("🫧 교정 적용 중...", "info", 1500);
                    try {
                        await executeUiRefinement(container, finalText);
                        showToast("🫧 교정 적용 완료!", "success", 2000);
                    } catch (err) {
                        showToast(`❌ 적용 실패: ${err.message}`, "info", 3000);
                    } finally {
                        isProcessing = false;
                    }
                };

                if (config.mode === 'auto') {
                    await applyAction(correctedText);
                } else {
                    // 수동 승인 팝업 노출 (3in1 AI 요약 스타일의 수동 다이얼로그 박스)
                    showConfirmModal(parsed.reason, correctedText, applyAction, () => { isProcessing = false; });
                }
            } else {
                isProcessing = false;
            }

        } catch (e) {
            showToast(`❌ 교정 실패: ${e.message}`, "info", 3000);
            isProcessing = false;
        }
    }

    // ==========================================
    // UI: 수동 승인 다이얼로그 팝업창
    // ==========================================
    function showConfirmModal(reason, suggestedText, onConfirm, onCancel) {
        const overlay = document.createElement('div');
        overlay.className = 'crack-ext-ai-overlay';
        overlay.id = `${SCRIPT_NS}-confirm-overlay`;

        overlay.innerHTML = `
            <div class="crack-ext-ai-modal" style="height: auto; max-height: 85vh;">
                <div class="crack-ext-ai-modal-header">
                    <h3>🫧 응답 교정 승인</h3>
                </div>
                <div class="ce-ai-body">
                    <label>교정 이유</label>
                    <div style="background: rgba(188,208,215,0.1); border: 1.5px solid ${ACCENT_COLOR}; padding: 12px; border-radius: 8px; font-size: 13px; font-weight:600; margin-bottom: 12px; color: #222 !important; box-sizing: border-box; line-height:1.5;">
                        ${escapeHtml(reason)}
                    </div>
                    <label>교정 적용본 (수정 가능)</label>
