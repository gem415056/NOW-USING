    // ==========================================
    // 관측 엔진: AI 메시지 출력 안정화 스캔
    // ==========================================
    let lastLength = 0;
    let idleCounter = 0;

    async function checkLatestAssistantMessage() {
        const config = loadSettings();
        const chatId = getChatRoomId();
        if (!chatId) return;

        try {
            const token = document.cookie.match(/(^| )access_token=([^;]+)/)?.[2];
            if (!token) return;

            const url = `https://contents-api.wrtn.ai/character-chat/v3/chats/${chatId}/messages?limit=1`;
            const res = await fetch(url, { headers: { 'Authorization': 'Bearer ' + token } });
            if (!res.ok) return;

            const json = await res.json();
            const lastMsg = json?.data?.messages?.[0];
            if (!lastMsg || lastMsg.role !== 'assistant') {
                lastLength = 0; idleCounter = 0;
                return;
            }

            const messageId = lastMsg._id || lastMsg.id;
            const text = lastMsg.content || '';
            const curLength = text.length;

            if (messageId !== lastCheckedMessageId) {
                // 새로운 메시지가 출력되기 시작함
                lastCheckedMessageId = messageId;
                lastLength = curLength;
                idleCounter = 0;
                return;
            }

            // 안정화(출력 완료) 감지 단계
            if (curLength === lastLength && curLength > 0) {
                idleCounter++;
                // 3초 이상 텍스트 변화가 없고 처리되지 않은 경우
                if (idleCounter >= 2) {
                    const fingerprints = JSON.parse(localStorage.getItem(`${SCRIPT_NS}-fingerprints`) || "[]");
                    if (!fingerprints.includes(messageId)) {
                        fingerprints.push(messageId);
                        localStorage.setItem(`${SCRIPT_NS}-fingerprints`, JSON.stringify(fingerprints.slice(-50)));
                        
                        // 안정화 완료 ➔ 교정 파이프라인 작동
                        const groups = Array.from(document.querySelectorAll('div[data-message-group-id]'));
                        const targetGroup = groups.find(g => g.getAttribute('data-message-group-id') === messageId);
                        if (targetGroup) {
                            await processRefiner(text, targetGroup, messageId);
                        }
                    }
                }
            } else {
                lastLength = curLength;
                idleCounter = 0;
            }

        } catch (e) {}
    }

