    function injectRefinerButton() {
        const toolWrapper = document.getElementById('custom-rp-tools');
        if (!toolWrapper) return;

        const divs = Array.from(toolWrapper.children);
        const spacers = divs.filter(el => el.tagName === 'DIV' && el.style.width === '28px' && !el.classList.contains('custom-rp-divider'));

        if (spacers.length < 3) return;

        const targetContainer = spacers[2]; // 기획서 상 3번째 물리 빈 공간
        if (targetContainer.querySelector('.crack-ext-refiner-btn')) return;

        const btn = document.createElement('button');
