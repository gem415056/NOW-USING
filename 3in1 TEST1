    function initKeywordNoteSystem() {
        let _capturedToken = '';
        let syncTimer = null;
        // 키워드 노트는 기존 색상(#FBA707) 독립적 유지
        const ACCENT_COLOR = '#FBA707';
        const BORDER_COLOR = '#D6D6D0';

        function getChatId() {
            try { if (typeof _w.CrackUtil !== 'undefined') { const c = _w.CrackUtil.path().chatRoom(); if (c) return c; } } catch(e){}
            try { if (typeof _w.__LoreCore !== 'undefined' && _w.__LoreCore.getCurrentChatId){ const o = _w.__LoreCore.getCurrentChatId(); if (o) return o; } } catch(e){}

            let m = location.pathname.match(/\/(?:chats|chat|episodes)\/[a-f0-9]+\/([a-f0-9]+)/);
            if (m) return m[1];
            let m2 = location.pathname.match(/\/(?:chats|chat|episodes)\/([a-f0-9]+)/);
            if (m2) return m2[1];
            return null;
        }

        function getToken() {
            try { if (typeof _w.CrackUtil !== 'undefined') { const t = _w.CrackUtil.cookie().getAuthToken(); if (t) return t; } } catch(e){}
            return _capturedToken;
        }

        const _origFetch = _w.fetch;
        _w.fetch = async function(...a) {
            try {
                const u = typeof a[0] === 'string' ? a[0] : a[0]?.url || '';
                if (u.includes('crack-api.wrtn.ai') || u.includes('contents-api.wrtn.ai')) {
                    const h = a[1]?.headers || {};
                    let t = '';
                    if (h instanceof Headers) t = h.get('Authorization') || h.get('authorization') || '';
                    else t = h['Authorization'] || h['authorization'] || '';
                    if (t) _capturedToken = t.replace('Bearer ', '');
                }
            } catch(e) {}
            return _origFetch.apply(this, a);
        };

        function getNoteData(chatId) {
            try {
                const data = localStorage.getItem(`Crack_KW_Note_${chatId}`);
                if (data) return JSON.parse(data);
            } catch (e) {}
            return { alwaysNote: "", keywords: [] };
        }

        function saveNoteData(chatId, data) {
            localStorage.setItem(`Crack_KW_Note_${chatId}`, JSON.stringify(data));
        }

        function escapeHtml(str) {
            if (!str) return "";
            return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        function getPlatformTextarea() {
            const tas = document.querySelectorAll('textarea');
            for (const ta of tas) {
                if (!ta.offsetParent) continue;
                if (ta.maxLength === 500 || ta.maxLength === 2000) {
                    const dialog = ta.closest('[role="dialog"], [aria-modal="true"], .modal, .dialog');
                    if (dialog) return ta;
                }
            }
            return null;
        }

        function setNativeValue(element, value) {
            try {
                const valueSetter = Object.getOwnPropertyDescriptor(element, 'value').set;
                const prototype = Object.getPrototypeOf(element);
                const prototypeValueSetter = Object.getOwnPropertyDescriptor(prototype, 'value').set;

                if (valueSetter && valueSetter !== prototypeValueSetter) {
                    prototypeValueSetter.call(element, value);
                } else {
                    valueSetter.call(element, value);
                }
            } catch(e) {
                element.value = value;
            }
        }

        function writeTextarea(text) {
            const ta = getPlatformTextarea();
            if (!ta) return;
            if (ta.value === text) return;
            
            setNativeValue(ta, text);
            ta.dispatchEvent(new Event('input', { bubbles: true }));
        }

        async function patchUserNoteAPI(chatId, content) {
            const token = getToken();
            if (!token || !chatId) return false;
            try {
                const ta = getPlatformTextarea();
                let isExt = false;
                if (ta) isExt = ta.maxLength > 500;
                else isExt = Array.from(content).length > 500; 

                const url = `https://crack-api.wrtn.ai/crack-gen/v3/chats/${chatId}`;
                const res = await _origFetch(url, {
                    method: 'PATCH',
                    credentials: 'include',
                    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userNote: { content: content, isExtend: isExt } })
                });
                return res.ok;
            } catch(e) {
                return false;
            }
        }

        async function forceSyncUserNote(chatId) {
            if (!chatId) return;
            const data = getNoteData(chatId);
            const activeId = localStorage.getItem(`Crack_Active_KW_${chatId}`) || 'always';
            
            let finalNoteText = data.alwaysNote || ""; 
            if (activeId !== 'always') {
                const kw = data.keywords.find(k => k.id === activeId);
                if (kw) finalNoteText = kw.content;
                else localStorage.setItem(`Crack_Active_KW_${chatId}`, 'always');
            }
            
            const isSuccess = await patchUserNoteAPI(chatId, finalNoteText);
            if (isSuccess) writeTextarea(finalNoteText);
        }

        function debouncedForceSync(chatId) {
            clearTimeout(syncTimer);
            syncTimer = setTimeout(() => forceSyncUserNote(chatId), 500);
        }

        function injectStyles() {
            if (document.getElementById('crack-kw-inline-css')) return;
            const s = document.createElement('style');
            s.id = 'crack-kw-inline-css';
            s.textContent = `
                .ckw-root {
                    margin-top: 12px; font-size: 13px; color: inherit;
                }
                .ckw-root * { box-sizing: border-box; }
                
                .ckw-ta {
