                return;
            }

            let maxTries = 15, currentTry = 0;
            const loadingToast = document.createElement('div');
            loadingToast.innerHTML = '북마크 위치 탐색 중...';
            loadingToast.style.cssText = `position:fixed; top:calc(50% - 101px); left:50%; transform:translate(-50%, -50%); background-color:#23343A; border:1.5px solid #88B9C8; color:#EFFCFF; padding:9px 14px; border-radius:9999px; z-index:2147483647; font-size:12px; font-weight:400; box-shadow:0 4px 16px rgba(0,0,0,0.3);`;
            document.body.appendChild(loadingToast);

            const searchLoop = setInterval(() => {
                applyHighlightsToDOM(); 
                const target = document.querySelector(`mark[data-bm-id="${id}"]`);
                if (target) {
                    clearInterval(searchLoop); loadingToast.remove();
                    target.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    target.classList.add('flash'); setTimeout(() => target.classList.remove('flash'), 1500);
                } else {
                    currentTry++;
                    if (currentTry > maxTries) { clearInterval(searchLoop); loadingToast.remove(); alert('탐색 실패. 너무 오래된 대화일 수 있습니다.'); return; }
                    window.scrollTo(0, 0); document.querySelectorAll('div').forEach(div => { if (div.scrollHeight > div.clientHeight) div.scrollTop = 0; });
                }
            }, 800);
        }

        injectStyles();
        setTimeout(applyHighlightsToDOM, 1000);
        
        const targetId = localStorage.getItem('cbm_jump_target');
        if (targetId) { localStorage.removeItem('cbm_jump_target'); setTimeout(() => jumpToHighlight(targetId, getChatId(), getStoryId()), 1500); }

        // [복구 완료] 기존과 동일하게 작동하며, "도착지만" 하단 툴바(빈자리1)로 바꾼 안전한 코드입니다.
        setInterval(() => {
            injectHeaderButton(); 
