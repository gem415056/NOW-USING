        function hexToRgba(hex, alpha = 0.4) {
            let r = parseInt(hex.slice(1, 3), 16), g = parseInt(hex.slice(3, 5), 16), b = parseInt(hex.slice(5, 7), 16);
            return `rgba(${r}, ${g}, ${b}, ${alpha})`;
        }
        function hexToRgb(hex) {
            let r = parseInt(hex.slice(1, 3), 16), g = parseInt(hex.slice(3, 5), 16), b = parseInt(hex.slice(5, 7), 16);
            return `rgb(${r}, ${g}, ${b})`;
        }
        function escapeHtml(s) {
            if (!s) return "";
            return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        // [중요 수정] 하단 툴바의 빈자리 1에 조준 (명령어 제거 버전 유지)
        function injectHeaderButton() {
            const toolWrapper = document.getElementById('custom-rp-tools');
            if (!toolWrapper) return;
            
            const divs = Array.from(toolWrapper.children);
            const spacers = divs.filter(el => el.tagName === 'DIV' && el.style.width === '28px' && !el.classList.contains('custom-rp-divider'));
            
            if (spacers.length < 2) return;
            
            const targetContainer = spacers[0];
            
            if (targetContainer.querySelector('.crack-ext-bm-btn')) return;
            
            const btn = document.createElement('button');
            btn.className = 'crack-ext-bm-btn relative inline-flex items-center justify-center rounded-full text-sm font-medium transition-colors border border-border bg-card text-line-gray-1 hover:bg-secondary p-0 size-7';
            btn.innerHTML = `<span style="font-size:15px; font-weight:normal; color:${ACCENT_COLOR};">♥</span>`; // ACCENT_COLOR(#F5E19A) 적용
            btn.title = '북마크';
            
            btn.onclick = (e) => { 
                e.preventDefault(); e.stopPropagation(); 
                savedSelectionText = realtimeSelectionText;
                openModal(); 
            };
            
            targetContainer.appendChild(btn);
        }

        function showBookmarkToast(message) {
            const toastId = "crack-bookmark-toast";
            const existing = document.getElementById(toastId);
            if (existing) existing.remove();

            const wrapperNode = document.createElement("div");
            wrapperNode.id = toastId;
            wrapperNode.style.cssText = `
                position: fixed;
                top: calc(50% - 101px);
                left: 50%;
                transform: translate(-50%, -50%) scale(0.9);
                opacity: 0;
                transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.2), opacity 0.15s ease;
                z-index: 999999999 !important;
                pointer-events: none;
                display: flex;
                justify-content: center;
                align-items: center;
                width: fit-content;
                height: fit-content;
            `;

            const containerNode = document.createElement("div");
            containerNode.style.cssText = `
                background-color: #23343A;
                border: 1.5px solid #88B9C8;
                padding: 9px 14px;
                border-radius: 9999px;
                display: inline-flex;
                justify-content: center;
                align-items: center;
                box-shadow: 0 4px 16px rgba(0,0,0,0.3);
                box-sizing: border-box;
            `;

            const textNode = document.createElement("p");
            textNode.textContent = message;
            textNode.style.cssText = `
                color: #EFFCFF;
                text-align: center;
                font-size: 12px;
                font-weight: 400;
                line-height: 100%;
                margin: 0;
                padding: 0;
                white-space: nowrap;
                user-select: none;
            `;

            containerNode.append(textNode);
            wrapperNode.append(containerNode);
            document.body.appendChild(wrapperNode);

            setTimeout(() => {
                wrapperNode.style.transform = "translate(-50%, -50%) scale(1)";
                wrapperNode.style.opacity = "1";
            }, 20);

            setTimeout(() => {
                if (document.body.contains(wrapperNode)) {
                    wrapperNode.style.transform = "translate(-50%, -50%) scale(0.93)";
                    wrapperNode.style.opacity = "0";
                    setTimeout(() => {
                        if (document.body.contains(wrapperNode)) {
                            wrapperNode.remove();
                        }
                    }, 200);
                }
            }, 3000);
        }

        function addBookmarkDirect(text, colorHex) {
            if (!text) return;
            const cid = getChatId();
            const sid = getStoryId();
            if (!cid) return alert("대화방 ID를 찾을 수 없습니다.");

            let bms = getBookmarks();
            bms.push({
                id: 'bm_' + Date.now(),
                chatId: cid, storyId: sid, text: text, color: colorHex,
                label: '새 북마크', folderId: 'default', timestamp: Date.now()
            });
            saveBookmarks(bms);
            showBookmarkToast("✨ 북마크가 추가되었습니다.");
        }

