                    </div>
                    
                    <!-- 설정 뷰 -->
                    <div id="ce-ai-settings-view" style="display:none; flex-direction:column; flex:1;">
                        <div class="crack-flex-ai-row">
                            <div class="fg" style="flex: 1.2;">
                                <label>API</label>
                                <select id="ce-ai-provider" class="ce-ai-select">
                                    <option value="google" ${savedProvider==='google'?'selected':''}>Google</option>
                                    <option value="firebase" ${savedProvider==='firebase'?'selected':''}>Firebase</option>
                                </select>
                            </div>
                            <div class="fg" id="ce-ai-key-container" style="${savedProvider==='google'?'':'display:none;'}">
                                <label>API Key</label>
                                <input type="password" id="ce-ai-key" class="ce-ai-input" value="${escapeHtml(savedApiKey)}">
                            </div>
                            <div class="fg" style="flex: 1.5;">
                                <label>모델</label>
                                <select id="ce-ai-model" class="ce-ai-select">
                                    <option value="gemini-3.1-pro-preview" ${savedModel==='gemini-3.1-pro-preview'?'selected':''}>3.1 Pro Preview</option>
                                    <option value="gemini-3.5-flash" ${savedModel==='gemini-3.5-flash'?'selected':''}>3.5 Flash</option>
                                    <option value="gemini-3-flash-preview" ${savedModel==='gemini-3-flash-preview'?'selected':''}>3 Flash Preview</option>
                                    <option value="gemini-3.1-flash-lite-preview" ${savedModel==='gemini-3.1-flash-lite-preview'?'selected':''}>3.1 Flash-Lite</option>
                                    <option value="gemini-2.5-pro" ${savedModel==='gemini-2.5-pro'?'selected':''}>2.5 Pro</option>
                                    <option value="gemini-2.5-flash" ${savedModel==='gemini-2.5-flash'?'selected':''}>2.5 Flash</option>
                                    <option value="gemini-2.5-flash-lite" ${savedModel==='gemini-2.5-flash-lite'?'selected':''}>2.5 Flash-Lite</option>
                                </select>
                            </div>
                            <div class="fg" style="flex: 0.8;">
                                <label>턴 수</label>
                                <input type="number" id="ce-ai-turns" class="ce-ai-input" value="${escapeHtml(savedTurnCount)}" min="0">
                            </div>
                        </div>
                        
                        <div class="crack-flex-ai-row" id="ce-ai-firebase-container" style="${savedProvider==='firebase'?'':'display:none;'}">
                            <div class="fg">
                                <label>Firebase 스크립트</label>
                                <textarea id="ce-ai-firebase-script" class="ce-ai-ta" style="flex: 0 0 60px; height:60px;">${escapeHtml(savedFirebaseScript)}</textarea>
                            </div>
                        </div>
                        
                        <div style="flex:1; display:flex; flex-direction:column; margin-top:4px;">
                            <label>프롬프트</label>
                            <textarea id="ce-ai-prompt" class="ce-ai-ta"></textarea>
                        </div>
                    </div>
                </div>
                
                <div class="ce-ai-footer">
                    <div>
                         <button class="crack-ext-ai-mbtn" id="ce-ai-settings-btn">요약 설정</button>
                    </div>
                    <div class="ce-ai-footer-right" id="ce-ai-footer-right">
                        <button class="crack-ext-ai-mbtn" id="ce-ai-generate">요약 생성</button>
                        <button class="crack-ext-ai-mbtn crack-ext-ai-mbtn-p" id="ce-ai-save">추가하기</button>
                    </div>
                </div>
            </div>`;

            overlay.innerHTML = html;
            document.body.appendChild(overlay);

            overlay.querySelector('#ce-ai-close-btn').onclick = e => { e.stopPropagation(); overlay.remove(); };
            overlay.addEventListener('click', e => { if(e.target === overlay) overlay.remove(); });

            const mainView = overlay.querySelector('#ce-ai-main-view');
            const settingsView = overlay.querySelector('#ce-ai-settings-view');
            const txtResult = overlay.querySelector('#ce-ai-result');
            const txtPrompt = overlay.querySelector('#ce-ai-prompt');
            const btnSettings = overlay.querySelector('#ce-ai-settings-btn');
            const footerRight = overlay.querySelector('#ce-ai-footer-right');
            
            const previewCards = overlay.querySelector('#ce-ai-preview-cards');
            const cardNav = overlay.querySelector('#ce-ai-card-nav');
            const spanCardPage = overlay.querySelector('#ce-ai-card-page');
            
            const selProvider = overlay.querySelector('#ce-ai-provider');
            const contKey = overlay.querySelector('#ce-ai-key-container');
            const contFirebase = overlay.querySelector('#ce-ai-firebase-container');

            selProvider.onchange = () => {
                if(selProvider.value === 'google') { contKey.style.display = 'block'; contFirebase.style.display = 'none'; } 
                else { contKey.style.display = 'none'; contFirebase.style.display = 'flex'; }
            };

            btnSettings.onclick = (e) => {
                e.preventDefault(); e.stopPropagation();
                if (mainView.style.display === 'none') {
                    localStorage.setItem('crack_ext_custom_prompt', txtPrompt.value.trim());
                    settingsView.style.display = 'none';
                    mainView.style.display = 'flex';
                    footerRight.style.display = 'flex';
                    btnSettings.textContent = '요약 설정';
                } else {
                    mainView.style.display = 'none';
                    settingsView.style.display = 'flex';
                    footerRight.style.display = 'none';
                    btnSettings.textContent = '돌아가기';
                    txtPrompt.value = localStorage.getItem('crack_ext_custom_prompt') || DEFAULT_PROMPT;
                }
            };

            function updatePreviewCards() {
                const content = txtResult.value.trim();
                
                if(!content || content === "요약 중..." || content.startsWith("오류:")) { 
                    previewCards.innerHTML = `<div class="crack-ext-session-card" style="justify-content:center; align-items:center;"><div style="color:#999; font-size:13px; font-weight:bold;">${content === "요약 중..." ? "🔄 요약 중..." : (content.startsWith("오류:") ? escapeHtml(content) : "이곳에 결과가 표시됩니다.")}</div></div>`;
                    cardNav.style.display = 'none'; 
                    parsedCards = []; 
                    return; 
                }

                const blocks = content.split(/\[(.*?)\]/);
                parsedCards = [];
                for (let i = 1; i < blocks.length; i += 2) {
                    let title = blocks[i].trim(), summary = blocks[i+1] ? blocks[i+1].replace(/^[\s\n]*[-*]?\s*/, '').trim() : '';
                    if (title || summary) parsedCards.push({ title, summary });
                }
                
                if (parsedCards.length === 0) {
                    previewCards.innerHTML = '<div class="crack-ext-session-card" style="justify-content:center; align-items:center;"><div style="color:#999; font-size:13px; font-weight:bold;">이곳에 결과가 표시됩니다.</div></div>';
                    cardNav.style.display = 'none'; 
                    return; 
                }
                
                if (currentCardIndex >= parsedCards.length) currentCardIndex = parsedCards.length - 1;
                if (currentCardIndex < 0) currentCardIndex = 0;

                cardNav.style.display = parsedCards.length > 1 ? 'flex' : 'none';
                spanCardPage.textContent = `${currentCardIndex + 1} / ${parsedCards.length}`;

                let mem = parsedCards[currentCardIndex];
                let tColor = mem.title.length > 20 ? 'color:#FF4433; font-weight:bold;' : 'color:inherit; font-weight:normal;';
                let sColor = mem.summary.length > 300 ? 'color:#FF4433; font-weight:bold;' : 'color:inherit; font-weight:normal;';

                previewCards.innerHTML = `
                    <div class="crack-ext-session-card">
                        <div class="crack-ext-session-title">
                            <div>
                                <span style="color:#888;">[ </span>
                                <span style="font-weight:bold; color:inherit;">${escapeHtml(mem.title)}</span>
                                <span style="color:#888;"> ]</span>
                            </div>
                            <span class="crack-ext-char-count">
                                ( <span style="${tColor}">${mem.title.length}자</span> / 20자 )
                            </span>
                        </div>
                        <div class="crack-ext-session-content">${escapeHtml(mem.summary)}</div>
                        <div style="text-align:right; margin-top:8px; flex-shrink:0;">
                            <span class="crack-ext-char-count">
                                ( <span style="${sColor}">${mem.summary.length}자</span> / 300자 )
                            </span>
                        </div>
                    </div>`;
            }

            txtResult.addEventListener('input', updatePreviewCards);
            overlay.querySelector('#ce-ai-card-prev').onclick = (e) => { e.preventDefault(); if (currentCardIndex > 0) { currentCardIndex--; updatePreviewCards(); } };
            overlay.querySelector('#ce-ai-card-next').onclick = (e) => { e.preventDefault(); if (currentCardIndex < parsedCards.length - 1) { currentCardIndex++; updatePreviewCards(); } };

            const btnGen = overlay.querySelector('#ce-ai-generate');
            const btnSave = overlay.querySelector('#ce-ai-save');

            btnGen.onclick = async (e) => {
                e.stopPropagation();
                if (settingsView.style.display === 'flex') {
                    localStorage.setItem('crack_ext_custom_prompt', txtPrompt.value.trim());
                    settingsView.style.display = 'none';
                    mainView.style.display = 'flex';
                    footerRight.style.display = 'flex';
                    btnSettings.textContent = '요약 설정';
                }

                const apiKey = overlay.querySelector('#ce-ai-key').value.trim(), model = overlay.querySelector('#ce-ai-model').value, turns = parseInt(overlay.querySelector('#ce-ai-turns').value, 10) || 15;
                const firebaseScript = overlay.querySelector('#ce-ai-firebase-script').value.trim();
                if (selProvider.value === 'google' && !apiKey) return alert("API Key를 입력해주세요.");
                
                localStorage.setItem('crack_ext_api_provider', selProvider.value);
                localStorage.setItem('crack_ext_gemini_key', apiKey);
                localStorage.setItem('crack_ext_firebase_script', firebaseScript);
                localStorage.setItem('crack_ext_gemini_model', model);
                localStorage.setItem('crack_ext_turn_count', turns.toString());

                btnGen.disabled = true; btnSave.disabled = true; txtResult.value = "요약 중..."; currentCardIndex = 0; updatePreviewCards();
                try {
                    const chatLog = await fetchRecentMessages(turns);
                    if (!chatLog) throw new Error("내역을 불러올 수 없습니다.");
                    txtResult.value = (selProvider.value === 'google') ? await callGeminiApi(apiKey, model, chatLog) : await callFirebaseApi(firebaseScript, model, chatLog);
                } catch (err) { txtResult.value = "오류: " + err.message; } 
                finally { btnGen.disabled = false; btnSave.disabled = false; btnGen.textContent = "재생성 (리롤)"; updatePreviewCards(); }
            };

            btnSave.onclick = async (e) => {
                e.stopPropagation();
                if (!txtResult.value.trim()) return alert("결과가 비어있습니다.");
                let errorIndex = parsedCards.findIndex(c => c.title.length > 20 || c.summary.length > 300);
                if (errorIndex !== -1) { currentCardIndex = errorIndex; updatePreviewCards(); return alert("글자 수 제한 초과 항목이 있습니다."); }

                btnSave.disabled = true;
                let successCount = 0;
                for (let i = 0; i < parsedCards.length; i++) {
                    btnSave.textContent = `추가 중... (${i + 1}/${parsedCards.length})`;
                    await new Promise(resolve => setTimeout(resolve, 50));
                    if (await apiCall('POST', '/summaries', { type: 'shortTerm', title: parsedCards[i].title, summary: parsedCards[i].summary })) successCount++;
                }
                if (successCount > 0) {
                    showToast(`✅ ${successCount}개의 요약이 장기 기억에 추가되었습니다.`);
                    overlay.remove();
                    var dialogEl = document.querySelector('[role="dialog"]');
                    if (dialogEl) refreshCurrentTab(dialogEl);
                } else { btnSave.textContent = "추가하기"; btnSave.disabled = false; }
            };

            updatePreviewCards();
        }

        function injectTopHeaderBtn() {
            const toolWrapper = document.getElementById('custom-rp-tools');
            if (!toolWrapper) return;
            
            const divs = Array.from(toolWrapper.children);
            const spacers = divs.filter(el => el.tagName === 'DIV' && el.style.width === '28px' && !el.classList.contains('custom-rp-divider'));
            
            if (spacers.length < 2) return;
            
            const targetContainer = spacers[1]; // 빈자리 2
            
            if (targetContainer.querySelector('.crack-ext-ai-btn')) return;
            
            const btn = document.createElement('button');
            btn.className = 'crack-ext-ai-btn relative inline-flex items-center justify-center rounded-full text-sm font-medium transition-colors border border-border bg-card text-line-gray-1 hover:bg-secondary p-0 size-7'; 
            btn.innerHTML = `<span style="font-size:15px; font-weight:normal; color:${ACCENT_COLOR};">♥</span>`; // ACCENT_COLOR(#F2C0C3) 적용
            btn.title = 'AI 요약';
            btn.addEventListener('click', (e) => { e.stopPropagation(); e.preventDefault(); showAiSummaryModal(); });
            
            targetContainer.appendChild(btn);
        }

        function inject() { 
            injectAiStyles(); 
            injectTopHeaderBtn(); 
        }

        // [원본 감지기 보존] 기존의 실행 방식 유지 (모달 등 타 기능용)
        let timeout;
        const obs = new MutationObserver(() => {
            clearTimeout(timeout);
            timeout = setTimeout(inject, 150);
        });
        obs.observe(document.body, { childList: true, subtree: true });
        
        setInterval(inject, 2000);
    }

    // ==========================================
    // 통합팩 동시 실행 관리 & 에러 핸들링
    // ==========================================
    function startAll() {
        try { 
            initBookmarkSystem(); 
        } catch (e) { 
            console.error("[ 통합팩 | 북마크 ] ❌ 모듈 오류 발생:", e); 
        }
        
        try { 
            initKeywordNoteSystem(); 
        } catch (e) { 
            console.error("[ 통합팩 | 키워드노트 ] ❌ 모듈 오류 발생:", e); 
        }

        try { 
            initAiSummarySystem(); 
        } catch (e) { 
            console.error("[ 통합팩 | AI요약 ] ❌ 모듈 오류 발생:", e); 
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', startAll);
    } else {
        startAll();
    }

})();
