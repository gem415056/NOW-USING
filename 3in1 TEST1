        function renderCountHTML(len, countDiv) {
            if(len > 500) {
                countDiv.innerHTML = `( <span style="color:#FF4433;">${len}자</span> / 500자 )`;
            } else {
                countDiv.innerHTML = `( ${len}자 / 500자 )`;
            }
        }

        function updateActiveUI() {
            const chatId = getChatId();
            if (!chatId) return;
            const activeId = localStorage.getItem(`Crack_Active_KW_${chatId}`) || 'always';
            document.querySelectorAll('.ckw-kw-item').forEach(item => {
                if (item.dataset.id === activeId) item.classList.add('is-active');
                else item.classList.remove('is-active');
            });
        }

        function renderPanel(root, chatId) {
            const data = getNoteData(chatId);
            
            root.innerHTML = `
                <div class="ckw-kw-item" id="ckw-always-item" data-id="always">
                    <div class="ckw-kw-head">
                        <span class="ckw-caret">></span>
                        <span class="ckw-kw-name">베이스 노트</span>
                    </div>
                    <div class="ckw-kw-body">
                        <textarea id="ckw-always-ta" class="ckw-ta" placeholder="키워드가 없을 때 상시로 들어갈 내용"></textarea>
                        <div class="ckw-char-count" id="ckw-always-count">( 0자 / 500자 )</div>
                    </div>
                </div>

                <div id="ckw-kw-list"></div>
                
                <div style="text-align:center; margin-top:10px;">
                    <button class="ckw-add-btn" title="키워드 추가">+</button>
                </div>
            `;
            
            const alwaysItem = root.querySelector('#ckw-always-item');
            const alwaysHead = alwaysItem.querySelector('.ckw-kw-head');
            const alwaysCaret = alwaysItem.querySelector('.ckw-caret');
            const alwaysTa = alwaysItem.querySelector('#ckw-always-ta');
            const alwaysCount = alwaysItem.querySelector('#ckw-always-count');

            alwaysHead.onclick = () => {
                const isOpen = alwaysItem.classList.contains('open');
                if (isOpen) {
                    alwaysItem.classList.remove('open');
                    alwaysCaret.textContent = '>';
                } else {
                    alwaysItem.classList.add('open');
                    alwaysCaret.textContent = '⌵';
                }
            };

            alwaysTa.value = data.alwaysNote || '';
            const updateAlwaysCount = () => {
                const len = [...alwaysTa.value].length;
                renderCountHTML(len, alwaysCount);
            };
            updateAlwaysCount();
            
            alwaysTa.oninput = () => {
                updateAlwaysCount();
                data.alwaysNote = alwaysTa.value;
                saveNoteData(chatId, data);
                debouncedForceSync(chatId);
            };

            const listDiv = root.querySelector('#ckw-kw-list');
            const renderList = () => {
                listDiv.innerHTML = '';
                if(!data.keywords) data.keywords = [];
                data.keywords.forEach((kw, idx) => {
                    const item = document.createElement('div');
                    item.className = 'ckw-kw-item';
                    item.dataset.id = kw.id;
                    
                    const head = document.createElement('div');
                    head.className = 'ckw-kw-head';
                    head.innerHTML = `
                        <span class="ckw-caret">></span>
                        <span class="ckw-kw-name">${escapeHtml(kw.name) || '이름 없음'}</span>
                        <div class="ckw-kw-actions">
                            <button class="ckw-icon-btn btn-up" title="위로" ${idx===0?'disabled':''}>▲</button>
                            <button class="ckw-icon-btn btn-down" title="아래로" ${idx===data.keywords.length-1?'disabled':''}>▼</button>
                            <button class="ckw-icon-btn btn-del" title="삭제">✘</button>
                        </div>
                    `;
                    
                    const body = document.createElement('div');
                    body.className = 'ckw-kw-body';
                    body.innerHTML = `
                        <div style="display: flex; gap: 8px; margin-bottom: 6px;">
                            <input type="text" class="ckw-input ckw-kw-name-inp" placeholder="이름" value="${escapeHtml(kw.name)}" style="flex: 1; margin: 0;">
                            <input type="text" class="ckw-input ckw-kw-trig-inp" placeholder="키워드 (쉼표 OR, && AND)" value="${escapeHtml(kw.triggers.join(', '))}" style="flex: 1; margin: 0;">
                        </div>
                        <textarea class="ckw-ta ckw-kw-cont-ta" placeholder="삽입될 내용">${escapeHtml(kw.content)}</textarea>
                        <div class="ckw-char-count ckw-kw-count">( 0자 / 500자 )</div>
                    `;

                    const caret = head.querySelector('.ckw-caret');
                    head.onclick = (e) => {
                        if (e.target.closest('button') || e.target.closest('input') || e.target.closest('textarea')) return;
                        const isOpen = item.classList.contains('open');
                        if (isOpen) {
                            item.classList.remove('open');
                            caret.textContent = '>';
                        } else {
                            item.classList.add('open');
                            caret.textContent = '⌵';
                        }
                    };
                    
                    head.querySelector('.btn-up').onclick = (e) => {
                        e.stopPropagation();
                        if (idx > 0) {
                            const temp = data.keywords[idx-1];
                            data.keywords[idx-1] = data.keywords[idx];
                            data.keywords[idx] = temp;
                            saveNoteData(chatId, data);
                            renderList(); debouncedForceSync(chatId);
                        }
                    };
                    head.querySelector('.btn-down').onclick = (e) => {
                        e.stopPropagation();
                        if (idx < data.keywords.length - 1) {
                            const temp = data.keywords[idx+1];
                            data.keywords[idx+1] = data.keywords[idx];
                            data.keywords[idx] = temp;
                            saveNoteData(chatId, data);
                            renderList(); debouncedForceSync(chatId);
                        }
                    };
                    head.querySelector('.btn-del').onclick = (e) => {
                        e.stopPropagation();
                        if(confirm("삭제하시겠습니까?")) {
                            data.keywords.splice(idx, 1);
                            saveNoteData(chatId, data);
                            renderList(); debouncedForceSync(chatId);
                        }
                    };

                    const nameInp = body.querySelector('.ckw-kw-name-inp');
                    const trigInp = body.querySelector('.ckw-kw-trig-inp');
                    const contTa = body.querySelector('.ckw-kw-cont-ta');
                    const countDiv = body.querySelector('.ckw-kw-count');
                    const nameSpan = head.querySelector('.ckw-kw-name');

                    const updateCnt = () => {
                        const len = [...contTa.value].length;
                        renderCountHTML(len, countDiv);
                    };
                    updateCnt();

                    const saveKw = () => {
                        kw.name = nameInp.value.trim();
                        kw.triggers = trigInp.value.split(',').map(s=>s.trim()).filter(Boolean);
                        kw.content = contTa.value;
                        nameSpan.textContent = kw.name || '이름 없음';
                        saveNoteData(chatId, data);
                        debouncedForceSync(chatId);
                    };

                    nameInp.oninput = saveKw;
                    trigInp.oninput = saveKw;
                    contTa.oninput = () => { updateCnt(); saveKw(); };

                    item.appendChild(head);
                    item.appendChild(body);
                    listDiv.appendChild(item);
                });
                updateActiveUI();
            };
            renderList();

            root.querySelector('.ckw-add-btn').onclick = () => {
                if(!data.keywords) data.keywords = [];
                data.keywords.push({ id: 'kw_'+Date.now(), name: '새 키워드', triggers: [], content: '' });
                saveNoteData(chatId, data);
                renderList();
            };
        }

        function findModal() {
            const tas = document.querySelectorAll('textarea');
            for (const ta of tas) {
                if (!ta.offsetParent) continue;
                if (ta.maxLength === 500 || ta.maxLength === 2000) {
                    const dialog = ta.closest('[role="dialog"], [aria-modal="true"], .modal, .dialog');
                    if (dialog) return dialog;
                }
            }
            return null;
        }

        function injectIntoModal(modal) {
            if (modal.querySelector('.ckw-root')) return;
            const chatId = getChatId(); if (!chatId) return;
            const ta = modal.getElementsByTagName('textarea')[0]; if (!ta) return;

            ta.readOnly = true;
            ta.style.minHeight = '160px'; 
            ta.style.maxHeight = '30vh'; 
            ta.style.opacity = '0.85';
            ta.placeholder = '현재 유저노트입니다. 아래 패널에서 자동 반영되며 직접 수정할 수 없습니다.';

            const data = getNoteData(chatId);
            const activeId = localStorage.getItem(`Crack_Active_KW_${chatId}`) || 'always';
            let currentContent = data.alwaysNote || "";
            if (activeId !== 'always') {
                const kw = data.keywords.find(k => k.id === activeId);
                if (kw) currentContent = kw.content;
            }
            writeTextarea(currentContent);

            const root = document.createElement('div');
            root.className = 'ckw-root';
            if (ta.nextSibling) ta.parentElement.insertBefore(root, ta.nextSibling);
            else ta.parentElement.appendChild(root);
            
            renderPanel(root, chatId);
        }

        function norm(s) { return (s || '').normalize('NFC').toLowerCase(); }
        
        function matchTriggers(text, triggers) {
            if (!triggers || !triggers.length) return false;
            const lowText = norm(text);
            for (const t of triggers) {
                const parts = t.split('&&').map(p => norm(p.trim())).filter(Boolean);
                if (parts.length && parts.every(p => lowText.includes(p))) return true;
            }
            return false;
        }

        async function fetchLastMessagesForScan(chatId) {
            try {
                if (typeof _w.CrackUtil !== 'undefined') {
                    const items = await _w.CrackUtil.chatRoom().extractLogs(chatId, { maxCount: 2 });
                    if (Array.isArray(items)) return items.map(m => m.content || '').join(' \n ');
                }
            } catch(e) {}
            
            const token = getToken();
            if (!token || !chatId) return "";
            try {
                const res = await _origFetch(`https://crack-api.wrtn.ai/crack-gen/v3/chats/${chatId}/messages?limit=2`, {
                    method: 'GET',
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                if (res.ok) {
                    const data = await res.json();
                    if (data && data.data && data.data.messages) {
                        return data.data.messages.map(m => m.content).join(' \n ');
                    }
                }
            } catch(e) {
                console.error("[ 통합팩 | 키워드노트 ] 최근 메시지 스캔 중 에러:", e);
            }
            return "";
        }

        async function processNoteSwap(chatId, userMessage) {
            try {
                const data = getNoteData(chatId);
                let finalNoteText = "";
                let activeKeyword = null;

                const pastMessages = await fetchLastMessagesForScan(chatId);
                const scanText = pastMessages + " \n " + userMessage;

                if (data.keywords && data.keywords.length > 0) {
                    for (const kw of data.keywords) {
                        if (matchTriggers(scanText, kw.triggers)) {
                            activeKeyword = kw;
                            break; 
                        }
                    }
                }
                
                if (activeKeyword) {
                    finalNoteText = activeKeyword.content;
                    localStorage.setItem(`Crack_Active_KW_${chatId}`, activeKeyword.id);
                } else {
                    finalNoteText = data.alwaysNote || "";
                    localStorage.setItem(`Crack_Active_KW_${chatId}`, 'always');
                }

                const isSuccess = await patchUserNoteAPI(chatId, finalNoteText);
                if (isSuccess) {
                    writeTextarea(finalNoteText);
                } else {
                    console.error("[ 통합팩 | 키워드노트 ] 유저노트 API 강제 주입 실패");
                }

            } catch (e) {
                console.error("[ 통합팩 | 키워드노트 ] 로직 처리 중 심각한 에러 발생:", e);
            }
        }

        const _origSend = _w.WebSocket.prototype.send;
        _w.WebSocket.prototype.send = function(wsData) {
            const ws = this;
            if (typeof wsData === 'string' && wsData.length > 10) {
                if (!_capturedToken && wsData.startsWith('40')) {
                    const ji = wsData.indexOf('{');
                    if (ji > 0) {
                        try {
                            const obj = JSON.parse(wsData.slice(ji));
                            if (obj && typeof obj.token === 'string') _capturedToken = obj.token.replace('Bearer ', '');
                        } catch(e) {}
                    }
                }

                const bi = wsData.indexOf('[');
                if (bi > 0) {
                    try {
                        const arr = JSON.parse(wsData.slice(bi));
                        if (Array.isArray(arr) && arr[0] === 'send' && arr[1] && typeof arr[1].message === 'string') {
                            const msg = arr[1].message;
                            const chatId = getChatId();
                            if (chatId) {
                                (async () => { 
                                    await processNoteSwap(chatId, msg); 
                                    _origSend.call(ws, wsData); 
                                })();
                                return; 
                            }
                        }
                    } catch(e) {}
                }
            }
            return _origSend.call(this, wsData);
        };

        function setupKW() {
            try {
                const modal = findModal();
                if (modal) injectIntoModal(modal);
                updateActiveUI();
            } catch(e) {
                console.error("[ 통합팩 | 키워드노트 UI 주입 에러 ]", e);
            }
        }

        injectStyles();
        setInterval(setupKW, 1000); 
        
        const obs = new MutationObserver(() => setupKW());
        obs.observe(document.body, { childList: true, subtree: true });
    }

